# =============================================================================
# ChainBridge Frontend Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in the values
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# =============================================================================

# =============================================================================
# API CONFIGURATION
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# =============================================================================
# STELLAR NETWORK
# =============================================================================
# Options: testnet, mainnet
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Soroban RPC URL
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Horizon RPC URL
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# =============================================================================
# BITCOIN NETWORK
# =============================================================================
# Options: testnet, mainnet
NEXT_PUBLIC_BITCOIN_NETWORK=testnet

# =============================================================================
# ETHEREUM NETWORK
# =============================================================================
# Options: testnet, mainnet
NEXT_PUBLIC_ETHEREUM_NETWORK=testnet

# Ethereum RPC (optional - uses MetaMask if not set)
NEXT_PUBLIC_ETHEREUM_RPC_URL=https://goerli.infura.io/v3/YOUR_INFURA_KEY

# =============================================================================
# CHAINBRIDGE CONTRACT
# =============================================================================
# Contract ID will be loaded from the backend
NEXT_PUBLIC_CHAINBRIDGE_CONTRACT_ID=

# =============================================================================
# FEATURE FLAGS
# =============================================================================
NEXT_PUBLIC_FEATURE_ORDERS_ENABLED=true
NEXT_PUBLIC_FEATURE_SWAPS_ENABLED=true

# =============================================================================
# ERROR MONITORING (#175)
# Set NEXT_PUBLIC_ERROR_REPORT_URL to your error-collection endpoint.
# Set NEXT_PUBLIC_ERROR_MONITORING_ENABLED=false to disable in development.
# =============================================================================
# NEXT_PUBLIC_ERROR_REPORT_URL=https://errors.example.com/ingest
NEXT_PUBLIC_ERROR_MONITORING_ENABLED=true

# =============================================================================
# TELEMETRY / WEB VITALS (#174)
# Set NEXT_PUBLIC_TELEMETRY_URL to your metrics endpoint (accepts JSON via beacon).
# Set NEXT_PUBLIC_TELEMETRY_ENABLED=false to disable entirely.
# =============================================================================
# NEXT_PUBLIC_TELEMETRY_URL=https://metrics.example.com/ingest
NEXT_PUBLIC_TELEMETRY_ENABLED=true

# =============================================================================
# ANALYTICS (Optional)
# =============================================================================
# NEXT_PUBLIC_GA_TRACKING_ID=

# =============================================================================
# APP CONFIGURATION
# =============================================================================
NEXT_PUBLIC_APP_NAME=ChainBridge
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
NEXT_PUBLIC_DEBUG=false
