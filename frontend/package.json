{
  "name": "chainbridge-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:smoke": "playwright test smoke-tests.spec.ts",
    "test:e2e:smoke:ci": "playwright test smoke-tests.spec.ts --reporter=list",
    "test:visual": "chromatic --exit-zero-on-changes",
    "test:visual:ci": "chromatic",
    "test:visual:local": "storybook test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "types:generate": "tsx scripts/generate-api-types.ts",
    "types:check": "tsc --noEmit --project tsconfig.json",
    "prebuild": "npm run types:generate"
  },
  "dependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@stellar/freighter-api": "^1.7.0",
    "@stellar/stellar-sdk": "^11.2.0",
    "@tanstack/react-query": "^5.95.2",
    "axios": "^1.6.5",
    "bitcoinjs-lib": "^6.1.5",
    "clsx": "^2.1.1",
    "ethers": "^6.10.0",
    "lucide-react": "^1.7.0",
    "next": "14.1.0",
    "next-themes": "^0.4.6",
    "react": "^18",
    "react-dom": "^19",
    "sats-connect": "^4.2.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-interactions": "^7.6.10",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/nextjs": "^10.3.5",
    "@storybook/test-runner": "^0.16.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/bitcoinjs-lib": "^5.0.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.17",
    "chromatic": "^11.5.6",
    "eslint": "^8",
    "eslint-config-next": "14.1.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.33",
    "prettier": "^3.2.5",
    "storybook": "^10.3.5",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.2",
    "typescript": "^5"
  }
}
